{
  "name": "qa-studio",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "prisma generate && vite build",
    "build:analyze": "prisma generate && ANALYZE=true vite build && node -e \"console.log('Open build-stats.html at the repository root for the bundle treemap.')\"",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "postinstall": "prisma generate || echo 'Prisma generate skipped'",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run && npm run test:e2e",
    "test:e2e": "playwright test",
    "test:e2e:headless": "playwright test --headed=false",
    "docker:dev": "docker-compose up",
    "docker:dev:build": "docker-compose up --build",
    "docker:dev:down": "docker-compose down",
    "docker:dev:clean": "docker-compose down -v",
    "docker:prod": "docker-compose -f docker-compose.yml -f docker-compose.prod.yml up -d",
    "docker:prod:build": "docker-compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build",
    "docker:logs": "docker-compose logs -f web",
    "docker:logs:all": "docker-compose logs -f",
    "docker:shell": "docker-compose exec web sh",
    "docker:restart": "docker-compose restart web",
    "docker:db:studio": "docker-compose exec web npx prisma studio",
    "docker:db:migrate": "docker-compose exec web npx prisma migrate dev",
    "docker:db:reset": "docker-compose exec web npx prisma migrate reset",
    "docker:db:seed": "docker-compose exec web npx prisma db seed",
    "docker:db:backup": "docker-compose exec postgres pg_dump -U qastudio qastudio > backup-$(date +%Y%m%d-%H%M%S).sql",
    "docker:db:restore": "echo 'Usage: docker-compose exec -T postgres psql -U qastudio qastudio < backup-file.sql'"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@fontsource/fira-mono": "^5.2.7",
    "@inlang/paraglide-js": "^2.18.1",
    "@neoconfetti/svelte": "^2.2.2",
    "@playwright/test": "^1.60.0",
    "@prisma/client": "^7.8.0",
    "@qastudio-dev/playwright": "^1.3.1",
    "@skeletonlabs/skeleton": "^4.15.2",
    "@skeletonlabs/skeleton-svelte": "^4.15.2",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@types/adm-zip": "^0.5.8",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22.19.19",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/simple-oauth2": "^5.0.8",
    "@types/swagger-ui-dist": "^3.30.6",
    "@vitest/browser": "^4.1.7",
    "@vitest/browser-playwright": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "mdsvex": "^0.12.7",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.0.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^7.8.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "svelte": "^5.56.0",
    "svelte-check": "^4.4.8",
    "svelte-meta-tags": "^4.7.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "vitest-browser-svelte": "^2.1.1"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/blob": "^2.4.0",
    "adm-zip": "^0.5.17",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "gray-matter": "^4.0.3",
    "html5-qrcode": "^2.3.8",
    "@lucide/svelte": "^1.17.0",
    "marked": "^18.0.4",
    "marked-highlight": "^2.2.4",
    "nanoid": "^5.1.11",
    "nodemailer": "^8.0.10",
    "openai": "^6.39.1",
    "otpauth": "^9.5.1",
    "pg": "^8.21.0",
    "shiki": "^4.1.0",
    "simple-oauth2": "^5.1.0",
    "stripe": "^22.2.0",
    "sveltekit-api": "^0.6.1",
    "swagger-ui-dist": "^5.32.6",
    "zod": "^4.4.3"
  },
  "overrides": {
    "@hono/node-server": ">=1.19.13",
    "cookie": "^0.7.0",
    "zod": "^4.4.3",
    "zod-validation-error": "^5.0.0",
    "sveltekit-api": {
      "@asteasolutions/zod-to-openapi": "^8.5.0",
      "zod": "^4.4.3",
      "zod-validation-error": "^5.0.0"
    }
  }
}
